<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/_110sdp"
    android:layout_height="@dimen/_110sdp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginStart="@dimen/_10sdp"
    android:layout_marginTop="@dimen/_5sdp"
    android:orientation="vertical">

    <androidx.nemosofts.material.ImageHelperView
        android:padding="@dimen/_1sdp"
        android:id="@+id/iv_albums"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/album"
        app:hv_corner_radius="@dimen/_3sdp"
        app:hv_border_color="?nsBorder"
        app:hv_border_width="@dimen/_1sdp"/>

    <TextView
        android:background="@drawable/shadow_up"
        android:id="@+id/tv_album_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:lineSpacingMultiplier="0.9"
        android:maxLines="1"
        android:paddingStart="@dimen/_5sdp"
        android:paddingEnd="@dimen/_5sdp"
        android:paddingBottom="@dimen/_10sdp"
        android:paddingTop="@dimen/_25sdp"
        android:text="@string/app_name"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="@dimen/_11ssp"
        android:layout_alignEnd="@id/iv_albums"
        android:layout_alignStart="@id/iv_albums"
        android:layout_alignBottom="@id/iv_albums"/>

</RelativeLayout>