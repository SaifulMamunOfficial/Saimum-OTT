<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_margin="@dimen/_15sdp"
        android:layout_centerInParent="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        tools:ignore="UselessParent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.nemosofts.material.ImageHelperView
                android:id="@+id/image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/placeholder_song_light"
                android:scaleType="centerCrop"
                app:hv_border_width="@dimen/_1sdp"
                app:hv_border_color="?nsBorder" />

            <RelativeLayout
                android:alpha="0.8"
                android:id="@+id/rl_text"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:background="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:ignore="RelativeOverlap"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/iv_vp_play"
                    android:layout_width="@dimen/_50sdp"
                    android:layout_height="@dimen/_50sdp"
                    android:translationZ="1dp"
                    android:layout_centerInParent="true"
                    android:background="@drawable/abs_history_playlist"
                    android:src="@drawable/ic_play"
                    android:backgroundTint="?nsPrimary"
                    app:tint="@color/white"
                    android:padding="@dimen/_8sdp"
                    android:contentDescription="@string/todo" />

                <ProgressBar
                    android:padding="@dimen/_3sdp"
                    android:id="@+id/loading"
                    android:layout_width="@dimen/_50sdp"
                    android:layout_height="@dimen/_50sdp"
                    android:layout_centerInParent="true"/>

            </RelativeLayout>

        </RelativeLayout>

    </RelativeLayout>

</RelativeLayout>