<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.ProfileActivity"
    android:id="@+id/bg_page"
    android:background="?nsBackground"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?nsBackground"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?nsBackground"
            app:titleTextColor="?nsBackgroundDark"
            app:navigationIconTint="?nsBackgroundDark"
            app:navigationIcon="@drawable/ic_back_modern"
            app:title="@string/profile"
            app:titleCentered="true"
            android:elevation="0dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:layout_marginEnd="@dimen/_12sdp">

                <!-- Modern Notification Button with Badge Design -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/iv_notifications"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="@dimen/_20sdp"
                    app:cardElevation="@dimen/_2sdp"
                    app:cardBackgroundColor="?nsBackgroundSub"
                    app:strokeWidth="@dimen/_1sdp"
                    app:strokeColor="?nsBorder"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notification"
                        app:tint="?nsBackgroundDark"
                        android:contentDescription="@string/todo" />

                    <!-- Notification Badge Indicator -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/_8sdp"
                        android:layout_height="@dimen/_8sdp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:layout_marginEnd="@dimen/_6sdp"
                        app:cardCornerRadius="@dimen/_4sdp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?colorPrimary">

                    </com.google.android.material.card.MaterialCardView>

                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/_12sdp"
            android:paddingEnd="@dimen/_12sdp"
            android:paddingBottom="@dimen/_60sdp">

            <!-- Profile Header Card - Compact -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_12sdp"
                android:layout_marginBottom="@dimen/_12sdp"
                app:cardCornerRadius="@dimen/_16sdp"
                app:cardElevation="@dimen/_4sdp"
                app:cardBackgroundColor="?nsBackground"
                app:strokeWidth="@dimen/_1sdp"
                app:strokeColor="?nsBorder">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/_20sdp"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/rl_profile"
                        android:layout_width="@dimen/_100sdp"
                        android:layout_height="@dimen/_100sdp">

                        <androidx.nemosofts.material.ImageHelperView
                            android:id="@+id/iv_profile"
                            android:layout_width="@dimen/_90sdp"
                            android:layout_height="@dimen/_90sdp"
                            android:layout_centerInParent="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/user_photo"
                            app:hv_border_color="?colorPrimary"
                            app:hv_border_width="@dimen/_2sdp"
                            app:hv_corner_radius="@dimen/_45sdp"
                            android:elevation="@dimen/_2sdp" />

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignStart="@+id/iv_profile"
                            android:layout_alignTop="@+id/iv_profile"
                            android:layout_alignEnd="@+id/iv_profile"
                            android:layout_alignBottom="@+id/iv_profile">

                            <ProgressBar
                                android:visibility="gone"
                                android:id="@+id/pb_iv_profile"
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                android:layout_centerInParent="true" />

                        </RelativeLayout>

                        <com.google.android.material.floatingactionbutton.FloatingActionButton
                            android:layout_width="@dimen/_32sdp"
                            android:layout_height="@dimen/_32sdp"
                            android:layout_alignEnd="@+id/iv_profile"
                            android:layout_alignBottom="@+id/iv_profile"
                            android:layout_marginEnd="@dimen/_2sdp"
                            android:layout_marginBottom="@dimen/_2sdp"
                            android:src="@drawable/ic_edit"
                            app:backgroundTint="?colorPrimary"
                            app:tint="@color/white"
                            app:fabSize="mini"
                            app:elevation="@dimen/_6sdp"
                            android:contentDescription="@string/todo" />

                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tv_profile_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:textColor="?nsTitle"
                        android:textSize="@dimen/_16ssp"
                        android:textStyle="bold"
                        android:text="@string/app_name"
                        android:letterSpacing="0.01" />

                    <TextView
                        android:id="@+id/tv_profile_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_2sdp"
                        android:textColor="?nsTitleSub"
                        android:text="@string/app_name"
                        android:textSize="@dimen/_12ssp"
                        android:alpha="0.8" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Settings & Actions Combined Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_12sdp"
                app:cardCornerRadius="@dimen/_16sdp"
                app:cardElevation="@dimen/_4sdp"
                app:cardBackgroundColor="?nsBackground"
                app:strokeWidth="@dimen/_1sdp"
                app:strokeColor="?nsBorder">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_12sdp">

                    <!-- Privacy Policy -->
                    <LinearLayout
                        android:id="@+id/ll_policy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/_12sdp"
                        android:background="?attr/selectableItemBackground"
                        android:layout_marginBottom="@dimen/_8sdp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/_36sdp"
                            android:layout_height="@dimen/_36sdp"
                            app:cardCornerRadius="@dimen/_18sdp"
                            app:cardElevation="@dimen/_2sdp"
                            app:cardBackgroundColor="?colorPrimary">

                            <ImageView
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/todo"
                                android:src="@drawable/ic_shield_keyhole"
                                app:tint="@color/white" />

                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/_12sdp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/privacy_policy"
                                android:textColor="?nsTitle"
                                android:textSize="@dimen/_13ssp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Data protection and privacy"
                                android:textColor="?nsTitleSub"
                                android:textSize="@dimen/_10ssp"
                                android:alpha="0.7" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:src="@drawable/ic_arrow_right_double"
                            app:tint="?nsTitleSub"
                            android:alpha="0.5"
                            android:contentDescription="@string/todo" />

                    </LinearLayout>

                    <!-- Terms & Conditions -->
                    <LinearLayout
                        android:id="@+id/ll_terms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/_12sdp"
                        android:background="?attr/selectableItemBackground"
                        android:layout_marginBottom="@dimen/_8sdp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/_36sdp"
                            android:layout_height="@dimen/_36sdp"
                            app:cardCornerRadius="@dimen/_18sdp"
                            app:cardElevation="@dimen/_2sdp"
                            app:cardBackgroundColor="#4CAF50">

                            <ImageView
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/todo"
                                android:src="@drawable/ic_todo"
                                app:tint="@color/white" />

                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/_12sdp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/terms_and_conditions"
                                android:textColor="?nsTitle"
                                android:textSize="@dimen/_13ssp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Rules and guidelines"
                                android:textColor="?nsTitleSub"
                                android:textSize="@dimen/_10ssp"
                                android:alpha="0.7" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:src="@drawable/ic_arrow_right_double"
                            app:tint="?nsTitleSub"
                            android:alpha="0.5"
                            android:contentDescription="@string/todo" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="?nsBorder"
                        android:alpha="0.3"
                        android:layout_marginVertical="@dimen/_4sdp" />

                    <!-- Delete Account -->
                    <LinearLayout
                        android:id="@+id/ll_trash"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/_12sdp"
                        android:background="?attr/selectableItemBackground"
                        android:layout_marginBottom="@dimen/_8sdp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/_36sdp"
                            android:layout_height="@dimen/_36sdp"
                            app:cardCornerRadius="@dimen/_18sdp"
                            app:cardElevation="@dimen/_2sdp"
                            app:cardBackgroundColor="#F44336">

                            <ImageView
                                android:layout_width="@dimen/_20sdp"
                                android:layout_height="@dimen/_20sdp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/todo"
                                android:src="@drawable/ic_trash"
                                app:tint="@color/white" />

                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/_12sdp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/delete_account"
                                android:textColor="?nsTitle"
                                android:textSize="@dimen/_13ssp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Remove your account"
                                android:textColor="?nsTitleSub"
                                android:textSize="@dimen/_10ssp"
                                android:alpha="0.7" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/_18sdp"
                            android:layout_height="@dimen/_18sdp"
                            android:src="@drawable/ic_arrow_right_double"
                            app:tint="?nsTitleSub"
                            android:alpha="0.5"
                            android:contentDescription="@string/todo" />

                    </LinearLayout>

                    <!-- Logout Button - Clean & Elegant -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/ll_logout"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_56sdp"
                        android:layout_marginBottom="@dimen/_12sdp"
                        android:text="@string/logout"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_14ssp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        app:backgroundTint="?colorPrimary"
                        app:cornerRadius="@dimen/_16sdp"
                        app:elevation="@dimen/_4sdp"
                        app:icon="@drawable/ic_logout"
                        app:iconTint="@color/white"
                        app:iconSize="@dimen/_20sdp"
                        app:iconGravity="start"
                        app:rippleColor="@color/white"
                        android:stateListAnimator="@null" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Ad View Container -->
    <LinearLayout
        android:id="@+id/ll_adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?nsBackground"
        android:orientation="vertical"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
