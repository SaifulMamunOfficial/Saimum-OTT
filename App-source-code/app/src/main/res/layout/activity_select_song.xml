<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activity.SelectSongActivity"
    android:id="@+id/bg_page"
    android:background="?nsBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_select"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?nsBackground"
        app:titleTextColor="?nsBackgroundDark"
        app:navigationIconTint="?nsBackgroundDark"
        app:navigationIcon="@drawable/ic_close_page"
        app:title="@string/add_songs"
        app:titleCentered="true" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_select"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <FrameLayout
        android:id="@+id/fl_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_select_add"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="12dp"
        android:layout_gravity="bottom"
        android:textColor="@color/white"
        android:background="@drawable/bg_view_all" />

</LinearLayout>