<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?nsBackground"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_playlist"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?nsBackground"
        app:titleTextColor="?nsBackgroundDark"
        app:navigationIconTint="?nsBackgroundDark"
        app:navigationIcon="@drawable/ic_back_modern"
        app:title="@string/playlist"
        app:titleCentered="true" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/_1sdp"
        android:background="?nsBorder" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?nsBackgroundSub">

        <LinearLayout
            android:id="@+id/ll_edit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/_8sdp"
            android:orientation="vertical"
            android:background="@drawable/bar_selector_playlist">

            <ImageView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:src="@drawable/ic_edit"
                android:contentDescription="@string/todo"
                app:tint="?nsTitle"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/edit"
                android:textSize="@dimen/_11ssp"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/_4sdp"
                android:textColor="?nsTitle"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_add_2_offplay"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/_8sdp"
            android:background="@drawable/bar_selector_playlist">

            <ImageView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:src="@drawable/ic_function_add"
                android:contentDescription="@string/todo"
                app:tint="?nsTitle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="@dimen/_4sdp"
                android:text="@string/add_to_playlist"
                android:textSize="@dimen/_11ssp"
                android:textStyle="bold"
                android:textColor="?nsTitle" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_addQueue"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/_8sdp"
            android:background="@drawable/bar_selector_playlist">

            <ImageView
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                app:tint="?nsTitle"
                android:src="@drawable/ic_audio_download"
                android:contentDescription="@string/todo" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="@dimen/_4sdp"
                android:text="@string/add_to_queue"
                android:textSize="@dimen/_11ssp"
                android:textStyle="bold"
                android:textColor="?nsTitle" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/_8sdp"
            android:background="@drawable/bar_selector_playlist">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                app:cardCornerRadius="@dimen/_4sdp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#20FF4444">

                <ImageView
                    android:layout_width="@dimen/_14sdp"
                    android:layout_height="@dimen/_14sdp"
                    android:layout_gravity="center"
                    app:tint="#FF4444"
                    android:src="@drawable/ic_close"
                    android:contentDescription="@string/todo" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="@dimen/_4sdp"
                android:text="@string/delete"
                android:textSize="@dimen/_11ssp"
                android:textStyle="bold"
                android:textColor="?nsTitle"/>

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/_1sdp"
        android:background="?nsBorder" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_song_by_playlist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/fl_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true" />

        <androidx.nemosofts.material.ProgressBarView
            android:id="@+id/pb_song_by_playlist"
            app:pb_color="#FFee44"
            app:pb_colors="@array/progress_colors"
            app:pb_max_sweep_angle="300"
            app:pb_min_sweep_angle="10"
            app:pb_rotation_speed="1.0"
            app:pb_stroke_width="@dimen/_4sdp"
            app:pb_sweep_speed="1.0"
            android:layout_width="@dimen/_40sdp"
            android:layout_height="@dimen/_40sdp"
            android:indeterminate="true"
            android:layout_centerInParent="true"/>

    </RelativeLayout>

</LinearLayout>