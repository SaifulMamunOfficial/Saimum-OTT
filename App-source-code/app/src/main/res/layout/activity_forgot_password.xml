<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="nemosofts.tamilaudiopro.activity.ForgotPasswordActivity"
    android:background="?nsBackground"
    android:id="@+id/bg_page"
    android:fitsSystemWindows="true">

    <!-- Modern App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?nsBackground"
        android:elevation="0dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?nsBackground"
            app:titleTextColor="?nsBackgroundDark"
            app:navigationIconTint="?nsBackgroundDark"
            app:navigationIcon="@drawable/ic_close"
            app:title="@string/forgot_pass"
            app:titleCentered="true"
            android:elevation="0dp" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content - Single Page Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/_20sdp"
        android:gravity="center"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Hero Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/_24sdp"
            app:cardElevation="@dimen/_8sdp"
            app:cardBackgroundColor="?nsBackground"
            app:strokeWidth="@dimen/_1sdp"
            app:strokeColor="?nsBorder">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_32sdp"
                android:gravity="center">

                <!-- Modern Icon with Background -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/_100sdp"
                    android:layout_height="@dimen/_100sdp"
                    android:layout_marginBottom="@dimen/_24sdp"
                    app:cardCornerRadius="@dimen/_50sdp"
                    app:cardElevation="@dimen/_6sdp"
                    app:cardBackgroundColor="?colorPrimary">

                    <ImageView
                        android:layout_width="@dimen/_50sdp"
                        android:layout_height="@dimen/_50sdp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/todo"
                        android:src="@drawable/ic_forgot"
                        app:tint="@color/white" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Enhanced Title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_12sdp"
                    android:text="@string/forgot_pass"
                    android:textAlignment="center"
                    android:textColor="?nsTitle"
                    android:textSize="@dimen/_24ssp"
                    android:textStyle="bold"
                    android:letterSpacing="0.01" />

                <!-- Better Description -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_24sdp"
                    android:text="@string/forgot_password_message"
                    android:textAlignment="center"
                    android:textColor="?nsTitleSub"
                    android:textSize="@dimen/_14ssp"
                    android:lineSpacingExtra="@dimen/_2sdp"
                    android:alpha="0.8" />

                <!-- Modern Email Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_24sdp"
                    app:boxStrokeColor="?colorPrimary"
                    app:boxStrokeWidth="@dimen/_2sdp"
                    app:boxCornerRadiusTopStart="@dimen/_16sdp"
                    app:boxCornerRadiusTopEnd="@dimen/_16sdp"
                    app:boxCornerRadiusBottomStart="@dimen/_16sdp"
                    app:boxCornerRadiusBottomEnd="@dimen/_16sdp"
                    app:hintTextColor="?nsBackgroundDark"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="?nsBackgroundDark"
                    app:hintAnimationEnabled="true"
                    app:expandedHintEnabled="true"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_forgot_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/email_id"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:textColor="?nsTitle"
                        android:textSize="@dimen/_14ssp"
                        android:paddingStart="@dimen/_4sdp"
                        android:paddingEnd="@dimen/_4sdp"
                        android:importantForAutofill="no" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Modern Submit Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ll_btn_forgot_send"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_56sdp"
                    android:text="@string/submit"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_16ssp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    app:backgroundTint="?colorPrimary"
                    app:cornerRadius="@dimen/_16sdp"
                    app:elevation="@dimen/_6sdp"
                    app:icon="@drawable/ic_send"
                    app:iconTint="@color/white"
                    app:iconSize="@dimen/_20sdp"
                    app:iconGravity="textStart"
                    app:rippleColor="@color/white"
                    android:stateListAnimator="@null" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Ad View Container -->
    <LinearLayout
        android:id="@+id/ll_adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?nsBackground"
        android:orientation="vertical"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
